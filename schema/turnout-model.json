{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "turnout-model",
  "title": "TurnModel",
  "description": "The JSON contract emitted by the Go converter (-format json) and consumed by the TypeScript scene-runner. This file is the single source of truth for the boundary; both packages/go/converter/internal/emit/json.go and packages/ts/scene-runner/src/types/scene-model.ts must stay in sync with it.",
  "type": "object",
  "required": ["scenes"],
  "additionalProperties": false,
  "properties": {
    "state": { "$ref": "#/$defs/StateModel" },
    "scenes": {
      "type": "array",
      "items": { "$ref": "#/$defs/SceneBlock" }
    },
    "routes": {
      "type": "array",
      "items": { "$ref": "#/$defs/RouteModel" }
    }
  },
  "$defs": {
    "FieldTypeStr": {
      "description": "The set of scalar and array field types understood by both the Go emitter and the TS runtime.",
      "type": "string",
      "enum": ["number", "str", "bool", "arr<number>", "arr<str>", "arr<bool>"]
    },
    "Literal": {
      "description": "A JSON-serialisable primitive or homogeneous array. Mixed-element arrays are not produced by the converter.",
      "oneOf": [
        { "type": "number" },
        { "type": "string" },
        { "type": "boolean" },
        { "type": "array", "items": { "type": "number" }, "minItems": 1 },
        { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        { "type": "array", "items": { "type": "boolean" }, "minItems": 1 },
        { "type": "array", "maxItems": 0 }
      ]
    },
    "StateModel": {
      "type": "object",
      "required": ["namespaces"],
      "additionalProperties": false,
      "properties": {
        "namespaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamespaceModel" }
        }
      }
    },
    "NamespaceModel": {
      "type": "object",
      "required": ["name", "fields"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/FieldModel" }
        }
      }
    },
    "FieldModel": {
      "type": "object",
      "required": ["name", "type", "value"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/$defs/FieldTypeStr" },
        "value": { "$ref": "#/$defs/Literal" }
      }
    },
    "SceneBlock": {
      "type": "object",
      "required": ["id", "entry_actions", "actions"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "entry_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_policy": {
          "description": "Absent means first-match (the default). Explicitly provided when the DSL sets a different policy.",
          "type": "string",
          "enum": ["first-match", "all-match"]
        },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/$defs/ActionModel" }
        }
      }
    },
    "ActionModel": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "compute": { "$ref": "#/$defs/ComputeModel" },
        "prepare": {
          "type": "array",
          "items": { "$ref": "#/$defs/PrepareEntry" }
        },
        "merge": {
          "type": "array",
          "items": { "$ref": "#/$defs/MergeEntry" }
        },
        "publish": {
          "description": "List of publish-hook names to invoke after action execution.",
          "type": "array",
          "items": { "type": "string" }
        },
        "next": {
          "type": "array",
          "items": { "$ref": "#/$defs/NextRuleModel" }
        }
      }
    },
    "ComputeModel": {
      "type": "object",
      "required": ["root", "prog"],
      "additionalProperties": false,
      "properties": {
        "root": {
          "description": "The binding name whose resolved value is the action's compute output.",
          "type": "string"
        },
        "prog": { "$ref": "#/$defs/ProgModel" }
      }
    },
    "ProgModel": {
      "type": "object",
      "required": ["name", "bindings"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/BindingModel" }
        }
      }
    },
    "BindingModel": {
      "description": "A single binding inside a prog. Exactly one of value or expr is present.",
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/$defs/FieldTypeStr" },
        "value": { "$ref": "#/$defs/Literal" },
        "expr": { "$ref": "#/$defs/ExprModel" }
      }
    },
    "ExprModel": {
      "description": "A functional expression. Exactly one of combine, pipe, or cond is present.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "combine": { "$ref": "#/$defs/CombineExpr" },
        "pipe": { "$ref": "#/$defs/PipeExpr" },
        "cond": { "$ref": "#/$defs/CondExpr" }
      }
    },
    "CombineExpr": {
      "type": "object",
      "required": ["fn", "args"],
      "additionalProperties": false,
      "properties": {
        "fn": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/ArgModel" }
        }
      }
    },
    "PipeExpr": {
      "type": "object",
      "required": ["params", "steps"],
      "additionalProperties": false,
      "properties": {
        "params": {
          "type": "array",
          "items": { "$ref": "#/$defs/PipeParam" }
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/PipeStep" }
        }
      }
    },
    "PipeParam": {
      "type": "object",
      "required": ["param_name", "source_ident"],
      "additionalProperties": false,
      "properties": {
        "param_name": { "type": "string" },
        "source_ident": { "type": "string" }
      }
    },
    "PipeStep": {
      "type": "object",
      "required": ["fn", "args"],
      "additionalProperties": false,
      "properties": {
        "fn": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "$ref": "#/$defs/ArgModel" }
        }
      }
    },
    "CondExpr": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "condition": { "$ref": "#/$defs/ArgModel" },
        "then": { "$ref": "#/$defs/ArgModel" },
        "else": { "$ref": "#/$defs/ArgModel" }
      }
    },
    "ArgModel": {
      "description": "A discriminated-union argument. Exactly one of ref, lit, func_ref, step_ref, or transform is present.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ref": {
          "description": "A binding-name reference within the same prog.",
          "type": "string"
        },
        "lit": {
          "description": "An inline literal value.",
          "$ref": "#/$defs/Literal"
        },
        "func_ref": {
          "description": "A reference to a function in the function table.",
          "type": "string"
        },
        "step_ref": {
          "description": "An index into the pipe steps array. 0 is valid, so this is always serialised as an integer (never omitted when present).",
          "type": "integer"
        },
        "transform": { "$ref": "#/$defs/TransformArg" }
      }
    },
    "TransformArg": {
      "type": "object",
      "required": ["ref", "fn"],
      "additionalProperties": false,
      "properties": {
        "ref": {
          "description": "The binding name to transform.",
          "type": "string"
        },
        "fn": {
          "description": "The transform function name (e.g. a method from transform-fn-dsl-spec.md).",
          "type": "string"
        }
      }
    },
    "PrepareEntry": {
      "description": "Action-level prepare entry. Exactly one of from_state or from_hook is present (from_literal is not supported at this level).",
      "type": "object",
      "required": ["binding"],
      "additionalProperties": false,
      "properties": {
        "binding": { "type": "string" },
        "from_state": {
          "description": "Dotted state path (e.g. 'session.userId') to read from.",
          "type": "string"
        },
        "from_hook": {
          "description": "Prepare-hook name whose result supplies this binding.",
          "type": "string"
        }
      }
    },
    "MergeEntry": {
      "type": "object",
      "required": ["binding", "to_state"],
      "additionalProperties": false,
      "properties": {
        "binding": { "type": "string" },
        "to_state": {
          "description": "Dotted state path to write the binding value into after execution.",
          "type": "string"
        }
      }
    },
    "NextRuleModel": {
      "description": "A conditional transition rule. compute (if present) guards the transition; prepare seeds the target action's bindings.",
      "type": "object",
      "required": ["action"],
      "additionalProperties": false,
      "properties": {
        "compute": { "$ref": "#/$defs/NextComputeModel" },
        "prepare": {
          "type": "array",
          "items": { "$ref": "#/$defs/NextPrepareEntry" }
        },
        "action": {
          "description": "ID of the target action.",
          "type": "string"
        }
      }
    },
    "NextComputeModel": {
      "type": "object",
      "required": ["condition", "prog"],
      "additionalProperties": false,
      "properties": {
        "condition": {
          "description": "Binding name within prog whose boolean value gates the transition.",
          "type": "string"
        },
        "prog": { "$ref": "#/$defs/ProgModel" }
      }
    },
    "NextPrepareEntry": {
      "description": "Transition-level prepare entry. Exactly one of from_action, from_state, or from_literal is present.",
      "type": "object",
      "required": ["binding"],
      "additionalProperties": false,
      "properties": {
        "binding": { "type": "string" },
        "from_action": {
          "description": "Binding name from the preceding action's compute result.",
          "type": "string"
        },
        "from_state": {
          "description": "Dotted state path to read.",
          "type": "string"
        },
        "from_literal": {
          "description": "An inline literal value.",
          "$ref": "#/$defs/Literal"
        }
      }
    },
    "RouteModel": {
      "type": "object",
      "required": ["id", "match"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "match": {
          "type": "array",
          "items": { "$ref": "#/$defs/MatchArm" }
        }
      }
    },
    "MatchArm": {
      "type": "object",
      "required": ["patterns", "target"],
      "additionalProperties": false,
      "properties": {
        "patterns": {
          "description": "One or more pattern strings OR-joined. '_' is the fallback arm. Path forms: 'scene_id.action_id' or 'scene_id.*.action_id[.action_id...]'.",
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "target": {
          "description": "Scene ID to enter when this arm matches.",
          "type": "string"
        }
      }
    }
  }
}
