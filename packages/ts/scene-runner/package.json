{
  "name": "turnout-scene-runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "gen:fn-map": "node --experimental-strip-types ../../../../scripts/gen-fn-map.ts",
    "lint": "oxlint src/",
    "fmt": "oxfmt",
    "test": "vitest --run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "runtime": "file:../runtime"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
