{
  "state": {
    "namespaces": [
      {
        "name": "input",
        "fields": [
          { "name": "value", "type": "number", "value": 0 }
        ]
      },
      {
        "name": "output",
        "fields": [
          { "name": "result", "type": "number", "value": 0 }
        ]
      }
    ]
  },
  "scenes": [
    {
      "id": "scene_a",
      "entryActions": ["step_a"],
      "actions": [
        {
          "id": "step_a",
          "compute": {
            "root": "doubled",
            "prog": {
              "name": "a_prog",
              "bindings": [
                { "name": "value", "type": "number", "value": 0 },
                {
                  "name": "doubled",
                  "type": "number",
                  "expr": {
                    "combine": {
                      "fn": "add",
                      "args": [{ "ref": "value" }, { "ref": "value" }]
                    }
                  }
                }
              ]
            }
          },
          "prepare": [
            { "binding": "value", "fromState": "input.value" }
          ],
          "merge": [
            { "binding": "doubled", "toState": "output.result" }
          ]
        }
      ]
    },
    {
      "id": "scene_b",
      "entryActions": ["step_b"],
      "actions": [
        {
          "id": "step_b",
          "compute": {
            "root": "final_val",
            "prog": {
              "name": "b_prog",
              "bindings": [
                { "name": "result", "type": "number", "value": 0 },
                { "name": "one", "type": "number", "value": 1 },
                {
                  "name": "final_val",
                  "type": "number",
                  "expr": {
                    "combine": {
                      "fn": "add",
                      "args": [{ "ref": "result" }, { "ref": "one" }]
                    }
                  }
                }
              ]
            }
          },
          "prepare": [
            { "binding": "result", "fromState": "output.result" }
          ],
          "merge": [
            { "binding": "final_val", "toState": "output.result" }
          ]
        }
      ]
    }
  ],
  "routes": [
    {
      "id": "main_route",
      "match": [
        { "patterns": ["scene_a.step_a"], "target": "scene_b" }
      ]
    }
  ]
}
