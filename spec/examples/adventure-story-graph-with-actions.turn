scene "adventure_story_chapter_1" {
  entry_actions     = ["choose_route"]
  next_policy       = "first-match"

  view "overview" {
    flow = <<-EOT
      choose_route
        |=> forest_trail
        |=> city_gate
        |=> sewer_tunnel
        |=> campfire_wait
      forest_trail
        |=> shrine_discovery
      city_gate
        |=> courtyard_arrival
      sewer_tunnel
        |=> hidden_archive
      campfire_wait
        |=> chapter_end
      shrine_discovery
        |=> chapter_end
      courtyard_arrival
        |=> chapter_end
      hidden_archive
        |=> chapter_end
    EOT
    enforce = "at_least"
  }

  action "choose_route" {
    """
    Logic overview:
    - Collect map/clue/coin/lockpick values from STATE inputs.
    - Compute route eligibility flags (`can_forest`, `can_gate`, `can_sewer`).
    - Persist chapter hub metadata after route selection.
    - Evaluate next actions in order: forest, gate, sewer, then campfire fallback.
    """

    compute {
      root     = decision_ready
      prog "choose_route_graph" {
        ~>has_map:bool = _
        ~>clue_count:int = _
        ~>coins:int = _
        ~>lockpick_skill:int = _
        <~chapter_state:str = "route_selected"
        <~last_hub:str = "crossroads"

        clue_enough:bool = clue_count >= 2
        can_forest:bool = has_map & clue_enough
        can_gate:bool = coins >= 3
        can_sewer:bool = lockpick_skill >= 1
        decision_ready:bool = true
      }
    }

    prepare {
      has_map        { from_state = story.flags.has_map      }
      clue_count     { from_state = story.clues.count        }
      coins          { from_state = party.inventory.coins    }
      lockpick_skill { from_state = party.skills.lockpick    }
    }

    merge {
      chapter_state { to_state = story.chapter_state }
      last_hub      { to_state = story.last_hub      }
    }

    next {
      compute {
        condition = go_forest
        prog "to_forest" {
          ~>can_forest:bool = _
          go_forest:bool = can_forest
        }
      }
      prepare {
        can_forest { from_action = can_forest }
      }
      action = forest_trail
    }

    next {
      compute {
        condition = go_gate
        prog "to_gate" {
          ~>can_gate:bool = _
          go_gate:bool = can_gate
        }
      }
      prepare {
        can_gate { from_action = can_gate }
      }
      action = city_gate
    }

    next {
      compute {
        condition = go_sewer
        prog "to_sewer" {
          ~>can_sewer:bool = _
          go_sewer:bool = can_sewer
        }
      }
      prepare {
        can_sewer { from_action = can_sewer }
      }
      action = sewer_tunnel
    }

    next {
      compute {
        condition = always
        prog "to_campfire" {
          always:bool = true
        }
      }
      action = campfire_wait
    }
  }

  action "forest_trail" {
    """
    Logic overview:
    - Set forest route metadata and a deterministic danger level.
    - Emit route, current location, and threat level to story state.
    - Always continue to `shrine_discovery`.
    """

    compute {
      root     = story_route
      prog "forest_trail_graph" {
        route:str = "forest_trail"
        <~location:str = "Whispering Forest"
        danger:int = 2

        <~story_route:str = route + ""
        <~danger_level:int = danger + 0
      }
    }

    merge {
      story_route  { to_state = story.route            }
      location     { to_state = story.current_location }
      danger_level { to_state = story.threat_level     }
    }

    next {
      compute {
        condition = always
        prog "to_shrine_discovery" {
          always:bool = true
        }
      }
      action = shrine_discovery
    }
  }

  action "city_gate" {
    """
    Logic overview:
    - Read current coins from STATE and apply the city gate toll.
    - Emit updated coin balance plus route/location updates.
    - Always continue to `courtyard_arrival`.
    """

    compute {
      root     = story_route
      prog "city_gate_graph" {
        route:str = "city_gate"
        <~location:str = "Stonebridge Gate"
        ~>coins:int = _
        toll:int = 3

        <~coins_after:int = coins - toll
        <~story_route:str = route + ""
      }
    }

    prepare {
      coins { from_state = party.inventory.coins }
    }

    merge {
      coins_after  { to_state = party.inventory.coins  }
      location     { to_state = story.current_location }
      story_route  { to_state = story.route            }
    }

    next {
      compute {
        condition = always
        prog "to_courtyard_arrival" {
          always:bool = true
        }
      }
      action = courtyard_arrival
    }
  }

  action "sewer_tunnel" {
    """
    Logic overview:
    - Read lockpick skill from STATE and evaluate hidden-mark discovery.
    - Emit route/location updates and discovery flag.
    - Always continue to `hidden_archive`.
    """

    compute {
      root     = story_route
      prog "sewer_tunnel_graph" {
        route:str = "sewer_tunnel"
        <~location:str = "Sunken Tunnel"
        ~>lockpick_skill:int = _

        <~found_mark:bool = lockpick_skill >= 2
        <~story_route:str = route + ""
      }
    }

    prepare {
      lockpick_skill { from_state = party.skills.lockpick }
    }

    merge {
      story_route  { to_state = story.route                   }
      location     { to_state = story.current_location        }
      found_mark   { to_state = story.flags.found_hidden_mark }
    }

    next {
      compute {
        condition = always
        prog "to_hidden_archive" {
          always:bool = true
        }
      }
      action = hidden_archive
    }
  }

  action "campfire_wait" {
    """
    Logic overview:
    - Set route and journal note for the wait-at-camp branch.
    - Emit route/journal fields and a fixed camp location value.
    - Always continue to `chapter_end`.
    """

    compute {
      root     = story_route
      prog "campfire_wait_graph" {
        route:str = "campfire_wait"
        <~note:str = "waited_until_dawn"
        <~location:str = "Crossroads Camp"
        <~story_route:str = route + ""
      }
    }

    merge {
      story_route { to_state = story.route            }
      note        { to_state = story.journal.latest   }
      location    { to_state = story.current_location }
    }

    next {
      compute {
        condition = always
        prog "to_chapter_end_after_wait" {
          always:bool = true
        }
      }
      action = chapter_end
    }
  }

  action "shrine_discovery" {
    """
    Logic overview:
    - Materialize shrine reward text from relic data.
    - Emit chapter reward and fixed shrine location.
    - Always continue to `chapter_end`.
    """

    compute {
      root     = reward
      prog "shrine_discovery_graph" {
        relic:str = "Moon Sigil"
        <~reward:str = relic + ""
        <~location:str = "Ruined Shrine"
      }
    }

    merge {
      reward   { to_state = story.chapter_reward    }
      location { to_state = story.current_location  }
    }

    next {
      compute {
        condition = always
        prog "to_chapter_end_after_shrine" {
          always:bool = true
        }
      }
      action = chapter_end
    }
  }

  action "courtyard_arrival" {
    """
    Logic overview:
    - Materialize city-branch reward text from writ data.
    - Emit chapter reward and fixed courtyard location.
    - Always continue to `chapter_end`.
    """

    compute {
      root     = reward
      prog "courtyard_arrival_graph" {
        writ:str = "Guest Writ"
        <~reward:str = writ + ""
        <~location:str = "Castle Courtyard"
      }
    }

    merge {
      reward   { to_state = story.chapter_reward   }
      location { to_state = story.current_location }
    }

    next {
      compute {
        condition = always
        prog "to_chapter_end_after_courtyard" {
          always:bool = true
        }
      }
      action = chapter_end
    }
  }

  action "hidden_archive" {
    """
    Logic overview:
    - Materialize archive-branch reward text from ledger data.
    - Emit chapter reward and fixed archive location.
    - Always continue to `chapter_end`.
    """

    compute {
      root     = reward
      prog "hidden_archive_graph" {
        ledger:str = "Old Kingdom Ledger"
        <~reward:str = ledger + ""
        <~location:str = "Hidden Archive"
      }
    }

    merge {
      reward   { to_state = story.chapter_reward   }
      location { to_state = story.current_location }
    }

    next {
      compute {
        condition = always
        prog "to_chapter_end_after_archive" {
          always:bool = true
        }
      }
      action = chapter_end
    }
  }

  action "chapter_end" {
    """
    Logic overview:
    - Build final chapter result identifier from prefix/suffix.
    - Mark chapter state as resolved and store the final result string.
    """

    compute {
      root     = chapter_result
      prog "chapter_end_graph" {
        prefix:str = "chapter_1_"
        suffix:str = "complete"
        <~chapter_result:str = prefix + suffix
        <~chapter_state:str = "resolved"
      }
    }

    merge {
      chapter_state  { to_state = story.chapter_state }
      chapter_result { to_state = story.result        }
    }
  }
}
